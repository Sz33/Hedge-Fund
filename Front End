            <div style={{ fontFamily:"monospace",fontSize:20,fontWeight:700,color:totalImpact>=0?t.green:t.red }}>{totalImpact>=0?"+":""}{pnlf(totalImpact)}</div>
          </div>
        </div>
      )}
      {!selected&&<div style={{ fontSize:12,color:t.muted,padding:"16px 0",textAlign:"center" }}>Select a scenario to stress-test the book</div>}
    </div>
  );
}

