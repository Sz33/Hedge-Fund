// Exponential decay — half-life at 30% of the decay window (not linear)
function decayFactorExp(ageMinutes, decayHours) {
  const halfLifeMin = decayHours * 0.30 * 60;
  const λ = Math.log(2) / halfLifeMin;
  return Math.max(0, Math.exp(-λ * ageMinutes));
}

// Proper weighted mean: Σ(score×weight) / Σ(weight) — not divided by count
function getNetScores(mode, timeDecay) {
  const agg = {};
  EVENTS.forEach(e => {
    const key    = mode==="HFT"?"hftImpact":mode==="Swing"?"swingImpact":mode==="Macro"?"macroImpact":"scores";
    const scores = e[key] || e.scores;
    const decay  = timeDecay ? decayFactorExp(e.ageMinutes, e.decayHours) : 1;
    const w      = (e.magnitude / 40) * decay;
    Object.entries(scores).forEach(([k,v]) => {
      if (!agg[k]) agg[k] = { wScore:0, wTotal:0 };
      agg[k].wScore += v * w;
      agg[k].wTotal += Math.abs(v) > 0 ? w : 0;
    });
  });
  const out = {};
  Object.entries(agg).forEach(([k,{wScore,wTotal}]) => {
    out[k] = wTotal > 0 ? Math.max(-5, Math.min(5, +(wScore/wTotal).toFixed(1))) : 0;
  });
  return out;
}

// Detect assets where significant events disagree — regime uncertainty signal
function getConflictAssets(mode) {
  const key = mode==="HFT"?"hftImpact":mode==="Macro"?"macroImpact":"swingImpact";
  const relevant = EVENTS.filter(e => e.magnitude >= 30);
  const assets = [...new Set(relevant.flatMap(e => Object.keys(e[key]||e.scores)))];
  const conflicts = {};
  assets.forEach(asset => {
    const vals = relevant.map(e=>(e[key]||e.scores)[asset]||0).filter(v=>Math.abs(v)>=2);
    if (vals.length >= 2 && vals.some(v=>v>0) && vals.some(v=>v<0)) conflicts[asset] = true;
  });
  return conflicts;
}

// Auto-detect regime from aggregated scores
function detectRegime(ns) {
  const dxy=ns["DXY"]||0, vix=ns["VIX"]||0, btc=ns["BTC"]||0, sp=ns["S&P 500"]||0;
  if (vix>=3 && dxy>=2)          return "RISK-OFF";
  if (vix>=2 && sp<=-1)          return "RISK-OFF";
  if (dxy>=3)                    return "DOLLAR BULL";
  if (btc>=3 && sp>=1)           return "RISK-ON";
  if (vix<=-2 && sp>=2)          return "RISK-ON";
  if (Math.abs(dxy)<=1 && Math.abs(vix)<=1 && Math.abs(sp)<=1) return "MIXED";
  if (dxy>=2)                    return "DOLLAR BULL";
  return "MIXED";
}

// Priority-based flag map (highest severity wins per position)
function getFlags() {
  const PRIORITY = ["critical","high","medium","low"];
  const map = {};
  EVENTS.forEach(e => {
    (e.flags||[]).forEach(f => {
      const inc = PRIORITY.indexOf(f.level);
      const ext = map[f.pos] ? PRIORITY.indexOf(map[f.pos].level) : Infinity;
      if (inc < ext) map[f.pos] = { ...f, mag:e.magnitude };
    });
  });
  return map;
}

// Book-level factor exposure
function getFactorExposure(positions) {
  const factors = { "DXY":0,"Risk-On":0,"Rates":0,"Oil":0 };
  positions.forEach(p => {
    const exp = FACTOR_EXPOSURES[p.name]; if (!exp) return;
    const dir = p.dir==="Long" ? 1 : -1;
    Object.keys(factors).forEach(f => { factors[f] += p.size * dir * (exp[f]||0); });
  });
  return factors;
}

function styleFlag(flag, style) {
  if (!style) return flag.reason;
  if (style==="HFT")   return `HFT: ${flag.reason}. Spike may exceed stop — exit immediately if triggered.`;
  if (style==="Swing") return `Swing: ${flag.reason}. Narrative shift affects 3–7 day bias.`;
  return flag.level==="critical"||flag.level==="high"
    ? `Macro thesis risk: ${flag.reason}. Evaluate if core thesis is broken.`
    : `Minor noise for macro timeframe. Monitor but no action.`;
}

// Quantified sizing recommendations — not just action labels
function getSizingRec(flag, pos) {
  const trimMap = { critical:50, high:30, medium:15, low:0 };
  const hedgeMap = { critical:100, high:70, medium:40, low:20 };
  if (flag.action==="TRIM")     { const p=trimMap[flag.level]; return `Trim ${p}% — reduce ${fmt(pos.size*p/100)}`; }
  if (flag.action==="HEDGE")    { const p=hedgeMap[flag.level]; return `Hedge ${p}% notional — ${fmt(pos.size*p/100)}`; }
  if (flag.action==="SCALE UP") return `Add ~25% — ${fmt(pos.size*0.25)} notional`;
  return flag.action;
}

function riskPerTrade(size, stopPct) { return size*(stopPct/100); }
function volAdjustedSize(size, stopPct) {
  const total = POSITIONS.reduce((s,p)=>s+p.size,0);
  const pctRisk = riskPerTrade(size,stopPct)/total;
  if (pctRisk>0.015) return "REDUCE";
  if (pctRisk<0.005) return "CAN SCALE";
  return "OPTIMAL";
}

// Key level proximity: how close (%) to the level, which direction
function levelProximity(kl) {
  const dist = Math.abs(kl.level - kl.current);
  const distPct = (dist / kl.current) * 100;
  const approaching = kl.type==="breakout"
    ? kl.current < kl.level   // approach breakout from below
    : kl.type==="support"
      ? kl.current > kl.level // approach support from above
      : kl.current < kl.level; // approach resistance from below
  return { distPct, approaching };
}

