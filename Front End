            </div>

            {/* Summary stats + P&L period toggle */}
            <div style={{ display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:9,marginBottom:14 }}>
              {[
                { label:"Total Notional",  value:fmt(totalSize),    color:t.text },
                { label:pnlPeriod==="pnl"?"P&L Since Open":pnlPeriod==="pnlToday"?"P&L Today":"P&L This Week", value:pnlf(totalPnl), color:totalPnl>=0?t.green:t.red },
                { label:"Positions",       value:positions.length,  color:t.blue },
                { label:"Flagged",         value:`${flaggedCount} / ${positions.length}`, color:flaggedCount>3?t.red:t.muted },
              ].map(s=>(
                <div key={s.label} style={{ background:t.card,border:`1px solid ${t.border}`,borderRadius:9,padding:"13px 15px" }}>
                  <div style={{ fontSize:9,color:t.muted,letterSpacing:1.2,marginBottom:4 }}>{s.label.toUpperCase()}</div>
                  <div style={{ fontFamily:"'DM Mono',monospace",fontSize:17,fontWeight:500,color:s.color }}>{s.value}</div>
                </div>
              ))}
            </div>

            {/* Controls row */}
            <div style={{ display:"flex",gap:10,marginBottom:12,flexWrap:"wrap",alignItems:"center" }}>
              {/* Style filter */}
              <div style={{ display:"flex",background:t.surface,border:`1px solid ${t.border}`,borderRadius:7,overflow:"hidden" }}>
                {["All","HFT","Swing","Macro"].map(s=>(
                  <button key={s} onClick={()=>setStyleFilter(s)} style={{ padding:"5px 13px",border:"none",cursor:"pointer",fontFamily:"inherit",fontSize:11,fontWeight:500,background:styleFilter===s?t.accent:(dark?"#1c2128":"#f8fafc"),color:styleFilter===s?(dark?"#0a0c0f":"white"):t.muted,transition:"0.15s" }}>{s}</button>
                ))}
              </div>
              {/* P&L period */}
              <div style={{ display:"flex",background:t.surface,border:`1px solid ${t.border}`,borderRadius:7,overflow:"hidden" }}>
                {[{id:"pnlToday",l:"Today"},{id:"pnlWeek",l:"Week"},{id:"pnl",l:"Since Open"}].map(p=>(
                  <button key={p.id} onClick={()=>setPnlPeriod(p.id)} style={{ padding:"5px 12px",border:"none",cursor:"pointer",fontFamily:"inherit",fontSize:10,background:pnlPeriod===p.id?t.accent2:(dark?"#1c2128":"#f8fafc"),color:pnlPeriod===p.id?(dark?"#0a0c0f":"white"):t.muted,transition:"0.15s" }}>{p.l}</button>
                ))}
              </div>
              {/* Sort */}
              <select value={portSort} onChange={e=>setPortSort(e.target.value)} style={{ padding:"5px 10px",borderRadius:7,border:`1px solid ${t.border}`,background:t.card,color:t.muted,fontSize:11,fontFamily:"inherit",outline:"none" }}>
                <option value="default">Sort: Default</option>
                <option value="pnl">Sort: P&L ↓</option>
                <option value="size">Sort: Size ↓</option>
                <option value="risk">Sort: Risk first</option>
              </select>
            </div>

            {/* Book factor risk */}
            <BookRiskCard dark={dark} positions={positions} />

            <div style={{ marginTop:14 }} />

            {/* Positions table */}
            <div style={{ background:t.card,border:`1px solid ${t.border}`,borderRadius:10,overflow:"hidden" }}>
              <div style={{ display:"grid",gridTemplateColumns:"1.4fr 75px 55px 85px 90px 95px 80px 80px 120px",padding:"9px 16px",borderBottom:`1px solid ${t.border}`,background:dark?"#1c2128":"#fafafa" }}>
                {["Instrument","Class","Dir","Size","P&L","Style","Alloc/Risk","Status","Action"].map(h=>(
                  <div key={h} style={{ fontSize:9,color:t.muted,letterSpacing:1 }}>{h.toUpperCase()}</div>
                ))}
              </div>
              {filteredPositions.map((p,idx)=>{
                const f=flagMap[p.name];
                const riskDollar=riskPerTrade(p.size,p.stopPct);
                const sizeStatus=volAdjustedSize(p.size,p.stopPct);
                const pnlVal=p[pnlPeriod]||0;
                return (
                  <div key={p.id} className="pos-row" style={{ display:"grid",gridTemplateColumns:"1.4fr 75px 55px 85px 90px 95px 80px 80px 120px",padding:"11px 16px",background:f?riskBg[f.level]:t.card,borderBottom:idx<filteredPositions.length-1?`1px solid ${t.faint}`:"none",borderLeft:f?`3px solid ${riskColor[f.level]}`:"3px solid transparent",alignItems:"center" }}>
                    <div style={{ display:"flex",alignItems:"center",gap:5 }}>
                      <span style={{ fontSize:12,color:t.text,fontWeight:500 }}>{p.name}</span>
                      {p.liquidity!=="high"&&<span style={{ fontSize:8,color:p.liquidity==="low"?t.red:dark?"#fb923c":"#ea580c",border:`1px solid ${p.liquidity==="low"?riskBr.medium:t.border}`,padding:"1px 4px",borderRadius:2 }} title={`Liquidity: ${p.liquidity}`}>{p.liquidity==="low"?"LOW LIQ":"MED LIQ"}</span>}
                    </div>
                    <div style={{ fontSize:10,color:assetColor[p.class]||t.muted }}>{p.class}</div>
                    <div style={{ fontSize:11,fontWeight:600,color:p.dir==="Long"?t.green:t.red }}>{p.dir.toUpperCase()}</div>
                    <div style={{ fontFamily:"'DM Mono',monospace",fontSize:11,color:t.muted }}>{fmt(p.size)}</div>
                    <div style={{ fontFamily:"'DM Mono',monospace",fontSize:11,fontWeight:500,color:pnlVal>=0?t.green:t.red }}>{pnlf(pnlVal)}</div>
                    <div style={{ display:"flex",alignItems:"center",gap:3 }}>
                      <select className="style-select" value={p.style} onChange={e=>setStyle(p.id,e.target.value)} style={{ background:STYLE_CONTEXT[p.style]?.[dark?"bg_d":"bg_l"]||t.faint,color:STYLE_CONTEXT[p.style]?.color||t.muted,border:`1px solid ${p.styleSet?t.border:"#fbbf24"}` }}>
                        <option value="HFT">HFT</option><option value="Swing">Swing</option><option value="Macro">Macro</option>
                      </select>
                      {!p.styleSet&&<span style={{ fontSize:8,color:t.accent }} title="Auto-inferred">~</span>}
                    </div>
                    <div>
                      <div style={{ fontFamily:"monospace",fontSize:10,color:t.muted }}>{p.allocation.toFixed(1)}%</div>
                      <div style={{ fontSize:9,color:sizeStatus==="REDUCE"?t.red:sizeStatus==="CAN SCALE"?t.green:t.muted,fontWeight:500 }}>{sizeStatus}</div>
                    </div>
                    <div>
                      {f?<span style={{ fontSize:10,color:riskColor[f.level],background:t.card,padding:"2px 6px",borderRadius:4,border:`1px solid ${riskBr[f.level]}` }}>{f.level.charAt(0).toUpperCase()+f.level.slice(1)}</span>:<span style={{ fontSize:10,color:t.muted }}>Clear</span>}
                    </div>
                    <div>
                      <span style={{ fontSize:10,background:f?(dark?"#2d220f":"#fffbeb"):t.faint,color:f?t.accent:t.muted,padding:"3px 8px",borderRadius:4,border:`1px solid ${f?(dark?"#7a4f1a":"#fcd34d"):t.border}`,fontWeight:f?500:400,display:"block",lineHeight:1.4 }}>
                        {f&&positions.find(p2=>p2.name===f.pos)?getSizingRec(f,p):(f?.action||"Hold")}
                      </span>
                    </div>
                  </div>
                );
              })}
              {filteredPositions.length===0&&(
                <div style={{ padding:"24px",textAlign:"center",color:t.muted,fontSize:12 }}>No {styleFilter} positions in book</div>
              )}
            </div>

            {/* Active flags */}
            {Object.values(flagMap).length>0&&(
              <div style={{ marginTop:14 }}>
                <div style={{ fontSize:10,color:t.muted,letterSpacing:1.5,marginBottom:9 }}>ACTIVE RISK FLAGS</div>
                <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:7 }}>
                  {Object.values(flagMap).sort((a,b)=>["critical","high","medium","low"].indexOf(a.level)-["critical","high","medium","low"].indexOf(b.level)).map((f,i)=>{
                    const pos=positions.find(p=>p.name===f.pos);
                    return (
                      <div key={i} style={{ background:riskBg[f.level],border:`1px solid ${riskBr[f.level]}`,borderRadius:8,padding:"11px 13px" }}>
                        <div style={{ display:"flex",justifyContent:"space-between",marginBottom:4,alignItems:"center" }}>
                          <div style={{ display:"flex",gap:6,alignItems:"center" }}>
                            <span style={{ fontSize:12,color:t.text,fontWeight:500 }}>{f.pos}</span>
                            {pos&&<span style={{ fontSize:9,background:STYLE_CONTEXT[pos.style]?.[dark?"bg_d":"bg_l"],color:STYLE_CONTEXT[pos.style]?.color,padding:"1px 6px",borderRadius:3 }}>{pos.style}</span>}
                          </div>
                          <span style={{ fontSize:9,color:riskColor[f.level],background:t.card,padding:"2px 7px",borderRadius:3,border:`1px solid ${riskBr[f.level]}` }}>{f.level.toUpperCase()}</span>
                        </div>
                        <div style={{ fontSize:11,color:t.muted,marginBottom:6,lineHeight:1.5 }}>{pos?styleFlag(f,pos.style):f.reason}</div>
                        <span style={{ fontSize:10,background:t.card,color:t.accent,padding:"3px 9px",borderRadius:4,border:`1px solid ${dark?"#7a4f1a":"#fcd34d"}`,fontWeight:500 }}>
                          {pos?getSizingRec(f,pos):f.action}
                        </span>
                      </div>
                    );
                  })}
                </div>
              </div>
            )}
          </div>
        )}

        {/* ── ANALYSIS ── */}
        {tab==="analysis" && (
          <div style={{ maxWidth:1100,display:"flex",flexDirection:"column",gap:20 }}>
            <div style={{ background:t.card,border:`1px solid ${t.border}`,borderRadius:12,padding:"20px 22px" }}>
              <CorrelationEngine dark={dark} />
            </div>
            <div style={{ background:t.card,border:`1px solid ${t.border}`,borderRadius:12,padding:"20px 22px" }}>
              <ScenarioSimulator positions={positions} dark={dark} />
            </div>
          </div>
        )}

        {/* ── JOURNAL ── */}
        {tab==="journal" && (
          <div style={{ maxWidth:900 }}>
            {/* Sample size warning */}
            <div style={{ background:dark?"#2d1b0f":"#fff7ed",border:`1px solid ${dark?"#9a3412":"#fdba74"}`,borderRadius:10,padding:"13px 18px",marginBottom:14 }}>
              <div style={{ fontSize:10,color:dark?"#fb923c":"#ea580c",letterSpacing:1.5,marginBottom:5 }}>STATISTICAL WARNING — INSUFFICIENT SAMPLE</div>
              <div style={{ fontSize:12,color:t.muted,lineHeight:1.7 }}>
                Current sample: <strong style={{ color:t.text }}>n={pnlLog.length} trades</strong>. Win rate requires minimum 30 trades for statistical significance (p &lt; 0.05). Current figures are directional only and should not be used to draw edge conclusions. Track at least 30 trades before evaluating pattern reliability.
              </div>
            </div>

            <div style={{ background:t.card,border:`1px solid ${t.border}`,borderRadius:12,padding:"20px 22px" }}>
              <div style={{ display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14 }}>
                <div>
                  <div style={{ fontSize:10,color:t.muted,letterSpacing:1.5,marginBottom:4 }}>PNL FEEDBACK ENGINE — EVENT → ACTION → OUTCOME</div>
                  <div style={{ fontSize:12,color:t.muted }}>Build edge by tracking which event types and assets produce the most reliable signals.</div>
                </div>
                <div style={{ textAlign:"right" }}>
                  <div style={{ fontSize:10,color:t.muted,marginBottom:2 }}>WIN RATE <span style={{ color:dark?"#fb923c":"#ea580c" }}>n={pnlLog.length}</span></div>
                  <div style={{ fontFamily:"monospace",fontSize:20,fontWeight:700,color:winRate>=0.6?t.green:winRate>=0.4?t.accent:t.red }}>{(winRate*100).toFixed(0)}%</div>
                </div>
              </div>
              <div style={{ background:t.surface,border:`1px solid ${t.border}`,borderRadius:8,overflow:"hidden",marginBottom:14 }}>
                <div style={{ display:"grid",gridTemplateColumns:"1fr 1.4fr 90px 90px 70px",padding:"8px 14px",borderBottom:`1px solid ${t.border}`,background:dark?"#1c2128":"#fafafa" }}>
                  {["Event / Type","Action Taken","Asset","Outcome","Result"].map(h=>(
                    <div key={h} style={{ fontSize:9,color:t.muted,letterSpacing:1 }}>{h.toUpperCase()}</div>
                  ))}
                </div>
                {pnlLog.map((l,i)=>(
                  <div key={i} style={{ display:"grid",gridTemplateColumns:"1fr 1.4fr 90px 90px 70px",padding:"11px 14px",borderBottom:i<pnlLog.length-1?`1px solid ${t.faint}`:"none",alignItems:"center" }}>
                    <div>
                      <div style={{ fontSize:12,color:t.muted }}>{l.event}</div>
                      <div style={{ fontSize:9,color:t.muted,marginTop:2,opacity:0.7 }}>{l.type}</div>
                    </div>
                    <div style={{ fontSize:11,color:t.text }}>{l.action}</div>
                    <div style={{ fontSize:11,color:assetColor[POSITIONS.find(p=>p.name===l.asset)?.class]||t.muted }}>{l.asset}</div>
                    <div style={{ fontFamily:"monospace",fontSize:12,fontWeight:600,color:l.outcome.startsWith("+")?t.green:t.red }}>{l.outcome}</div>
                    <div><span style={{ fontSize:10,background:l.worked?(dark?"#0d2b1a":"#dcfce7"):(dark?"#2d0f0f":"#fef2f2"),color:l.worked?t.green:t.red,padding:"3px 8px",borderRadius:4,fontWeight:500 }}>{l.worked?"✓ WORKED":"✗ MISS"}</span></div>
                  </div>
                ))}
              </div>
              <div style={{ display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:9 }}>
                {edgeSummary.map(s=>(
                  <div key={s.label} style={{ background:dark?"#1c2128":"#f8fafc",border:`1px solid ${t.border}`,borderRadius:8,padding:"12px 14px" }}>
                    <div style={{ fontSize:9,color:t.muted,letterSpacing:1,marginBottom:4 }}>{s.label.toUpperCase()}</div>
                    <div style={{ fontSize:13,color:t.text,fontWeight:600,marginBottom:3 }}>{s.value}</div>
                    <div style={{ fontSize:11,color:t.muted }}>{s.sub}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}

      </div>

      {/* ── FLOATING AI BUTTON + PANEL ── */}
      <AIPanel dark={dark} open={aiOpen} onClose={()=>setAiOpen(false)} />
      <button onClick={()=>setAiOpen(o=>!o)} style={{
        position:"fixed",bottom:20,right:24,zIndex:999,
        background:aiOpen?t.accent2:t.card,border:`1px solid ${aiOpen?t.accent2:t.border}`,
        borderRadius:50,padding:"9px 16px",cursor:"pointer",fontFamily:"inherit",
        display:"flex",alignItems:"center",gap:7,
        boxShadow:`0 4px 20px rgba(0,0,0,${dark?0.5:0.12})`,
        color:aiOpen?"white":t.text,fontSize:12,fontWeight:500,
        transition:"all 0.2s",
      }}>
        <span style={{ fontSize:14 }}>⚡</span>
        {aiOpen?"Close":"AI Analyst"}
      </button>
    </div>
  );
}
