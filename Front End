function CorrelationEngine({ dark }) {
  const t = T[dark?"dark":"light"];
  const [driver, setDriver] = useState("WTI Crude");
  const [movePct, setMovePct] = useState(4);
  const corrs  = CORRELATION_MATRIX[driver]||{};
  const sorted = Object.entries(corrs).sort((a,b)=>Math.abs(b[1])-Math.abs(a[1]));
  const projected = sorted.map(([asset,corr])=>({ asset,corr,projected:+(corr*movePct).toFixed(2),diverging:Math.abs(corr*movePct)>1.5 }));
  return (
    <div style={{ display:"flex",flexDirection:"column",gap:14 }}>
      <div style={{ fontSize:10,color:t.muted,letterSpacing:1.5 }}>DYNAMIC CORRELATION ENGINE — 30-DAY ROLLING</div>
      <div style={{ display:"flex",gap:10,alignItems:"center",flexWrap:"wrap" }}>
        <div>
          <div style={{ fontSize:10,color:t.muted,marginBottom:4 }}>DRIVER</div>
          <select value={driver} onChange={e=>setDriver(e.target.value)} style={{ padding:"6px 10px",borderRadius:6,border:`1px solid ${t.border}`,background:t.card,color:t.text,fontSize:12,fontFamily:"inherit",outline:"none" }}>
            {Object.keys(CORRELATION_MATRIX).map(k=><option key={k}>{k}</option>)}
          </select>
        </div>
        <div>
          <div style={{ fontSize:10,color:t.muted,marginBottom:4 }}>MOVE SIZE</div>
          <div style={{ display:"flex",alignItems:"center",gap:8 }}>
            <input type="range" min={-10} max={15} value={movePct} onChange={e=>setMovePct(+e.target.value)} style={{ width:110 }} />
            <span style={{ fontFamily:"monospace",fontSize:13,color:movePct>=0?t.green:t.red,fontWeight:600,minWidth:40 }}>{movePct>0?"+":""}{movePct}%</span>
          </div>
        </div>
        <div style={{ fontSize:11,color:t.muted,marginTop:16 }}>
          If <span style={{ color:t.accent,fontWeight:600 }}>{driver}</span> moves <span style={{ color:movePct>=0?t.green:t.red,fontWeight:600 }}>{movePct>0?"+":""}{movePct}%</span>:
        </div>
      </div>
      <div style={{ display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(150px,1fr))",gap:8 }}>
        {projected.map(({ asset,corr,projected,diverging })=>(
          <div key={asset} style={{ background:diverging?(dark?"#2d220f":"#fffbeb"):t.card,border:`1px solid ${diverging?t.accent:t.border}`,borderRadius:8,padding:"10px 12px" }}>
            <div style={{ display:"flex",justifyContent:"space-between",marginBottom:4 }}>
              <span style={{ fontSize:11,color:t.text,fontWeight:500 }}>{asset}</span>
              {diverging&&<span style={{ fontSize:8,background:t.accent,color:"white",padding:"1px 5px",borderRadius:3 }}>ALERT</span>}
            </div>
            <div style={{ fontSize:9,color:t.muted,marginBottom:4 }}>ρ = {corr.toFixed(2)}</div>
            <div style={{ fontFamily:"monospace",fontSize:15,fontWeight:700,color:projected>0?t.green:t.red }}>{projected>0?"+":""}{projected}%</div>
          </div>
        ))}
      </div>
    </div>
  );
}

