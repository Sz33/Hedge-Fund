// SCENARIO SIMULATOR
// ─────────────────────────────────────────────────────────────────────────────
function ScenarioSimulator({ positions, dark }) {
  const t = T[dark?"dark":"light"];
  const [selected, setSelected] = useState(null);
  const total = positions.reduce((s,p)=>s+p.size,0);

  const results = useMemo(()=>{
    if(!selected) return [];
    return positions.map(p=>{
      let shock=0, corrDerived=false;
      const ck = POS_CORR_KEY[p.name];
      if (selected.driver && ck && CORRELATION_MATRIX[selected.driver]?.[ck]!==undefined && !selected.overrides?.[p.name]) {
        shock = +(CORRELATION_MATRIX[selected.driver][ck]*selected.baseMove).toFixed(3);
        corrDerived = true;
      } else if (selected.overrides?.[p.name]!==undefined) {
        shock = selected.overrides[p.name];
      }
      return { ...p, shock, pnlImpact:p.size*shock*(p.dir==="Long"?1:-1), corrDerived };
    }).filter(p=>Math.abs(p.shock)>0.001).sort((a,b)=>Math.abs(b.pnlImpact)-Math.abs(a.pnlImpact));
  },[selected,positions]);

  const totalImpact = results.reduce((s,r)=>s+r.pnlImpact,0);

  return (
    <div style={{ display:"flex",flexDirection:"column",gap:14 }}>
      <div style={{ fontSize:10,color:t.muted,letterSpacing:1.5 }}>SCENARIO STRESS TEST — PORTFOLIO IMPACT</div>
      {/* Stress correlation warning */}
      <div style={{ background:dark?"#2d1b0f":"#fff7ed",border:`1px solid ${dark?"#9a3412":"#fdba74"}`,borderRadius:8,padding:"9px 13px",fontSize:11,color:dark?"#fb923c":"#ea580c",lineHeight:1.7 }}>
        ⚠ <strong>Correlation warning:</strong> During tail events, cross-asset correlations converge toward 1.0. Correlated long positions move together adversely. Actual stress losses are typically <strong>1.5–2.5× these estimates</strong>. Liquidity haircuts not modeled.
      </div>
      <div style={{ display:"flex",gap:6,flexWrap:"wrap" }}>
        {SCENARIOS.map(s=>(
          <button key={s.label} onClick={()=>setSelected(selected?.label===s.label?null:s)} style={{ padding:"6px 12px",borderRadius:6,border:`1px solid ${selected?.label===s.label?t.accent:t.border}`,background:selected?.label===s.label?(dark?"#2d220f":"#fffbeb"):t.card,color:selected?.label===s.label?t.accent:t.muted,fontSize:11,fontWeight:500,cursor:"pointer",fontFamily:"inherit" }}>
            {s.label}
          </button>
        ))}
      </div>
      {selected&&(
        <div style={{ display:"flex",flexDirection:"column",gap:8 }} className="fadein">
          <div style={{ display:"flex",justifyContent:"space-between",alignItems:"center" }}>
            <div style={{ fontSize:11,color:t.muted }}>{selected.desc} — on ${(total/1e6).toFixed(1)}M book</div>
            {selected.driver&&<div style={{ fontSize:10,color:t.accent,background:dark?"#1c2128":"#f8fafc",border:`1px solid ${t.border}`,padding:"2px 8px",borderRadius:4 }}>ρ-derived where available</div>}
          </div>
          <div style={{ display:"grid",gridTemplateColumns:"1fr 70px 90px 100px 20px",gap:1,background:t.border,borderRadius:8,overflow:"hidden" }}>
            {["Position","Dir","Shock","Est. P&L",""].map(h=>(
              <div key={h} style={{ padding:"7px 12px",background:dark?"#1c2128":"#f8fafc",fontSize:9,color:t.muted,letterSpacing:1 }}>{h}</div>
            ))}
            {results.map(r=>(
              <Fragment key={r.id}>
                <div style={{ padding:"9px 12px",background:t.card,fontSize:12,color:t.text }}>{r.name}</div>
                <div style={{ padding:"9px 12px",background:t.card,fontSize:11,fontWeight:600,color:r.dir==="Long"?t.green:t.red }}>{r.dir.toUpperCase()}</div>
                <div style={{ padding:"9px 12px",background:t.card,fontSize:11,fontFamily:"monospace",color:r.shock>0?t.green:t.red }}>{r.shock>0?"+":""}{(r.shock*100).toFixed(1)}%</div>
                <div style={{ padding:"9px 12px",background:t.card,fontSize:11,fontFamily:"monospace",fontWeight:600,color:r.pnlImpact>0?t.green:t.red }}>{r.pnlImpact>0?"+":""}{pnlf(r.pnlImpact)}</div>
                <div style={{ padding:"9px 6px",background:t.card,display:"flex",alignItems:"center",justifyContent:"center" }}>
                  {r.corrDerived&&<span title="ρ-derived" style={{ fontSize:9,color:t.accent,fontFamily:"monospace" }}>ρ</span>}
                </div>
              </Fragment>
            ))}
          </div>
          <div style={{ background:totalImpact>=0?(dark?"#0d2b1a":"#ecfdf5"):(dark?"#2d0f0f":"#fef2f2"),border:`1px solid ${totalImpact>=0?(dark?"#2ea043":"#6ee7b7"):(dark?"#b91c1c":"#fca5a5")}`,borderRadius:8,padding:"11px 16px",display:"flex",justifyContent:"space-between",alignItems:"center" }}>
            <div>
              <div style={{ fontSize:10,color:t.muted,letterSpacing:1,marginBottom:2 }}>MODELED IMPACT — {selected.label.toUpperCase()}</div>
